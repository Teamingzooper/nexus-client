{
  "name": "nexus",
  "productName": "Nexus",
  "version": "1.4.0",
  "description": "Modular desktop messaging client — a moddable wrapper for messaging web portals",
  "author": {
    "name": "Teamingzooper"
  },
  "homepage": "https://github.com/Teamingzooper/nexus-client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teamingzooper/nexus-client.git"
  },
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n MAIN,RENDERER,ELECTRON -c blue,green,magenta \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json -w --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 ./dist/main/main/index.js && cross-env NEXUS_DEV=1 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "launch": "npm run build && electron-builder --mac --arm64 --dir --config.compression=store && open release/mac-arm64/Nexus.app",
    "launch:electron": "npm run build && electron .",
    "launch:win": "npm run build && electron-builder --win --dir && start release\\win-unpacked\\Nexus.exe",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && electron-builder --mac --arm64 --dir --config.compression=store && playwright test",
    "test:e2e:win": "npm run build && electron-builder --win --dir && playwright test",
    "bench": "vitest run --config vitest.bench.config.ts tests/bench",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --arm64 && electron-builder --mac --x64",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.teamingzooper.nexus",
    "productName": "Nexus",
    "copyright": "Copyright © 2026 Teamingzooper",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsbuildinfo",
      "!**/tsconfig*.json"
    ],
    "extraResources": [
      {
        "from": "modules",
        "to": "modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Nexus ${version}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Teamingzooper",
        "repo": "nexus-client",
        "releaseType": "release"
      }
    ]
  }
}
